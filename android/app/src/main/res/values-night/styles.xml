<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the OS's Dark Mode setting is on -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <!-- This drawable shows the green background and logo IMMEDIATELY even in dark mode -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Theme applied as soon as the process has started.
         We set the background to our primary green to avoid a white flash during handoff to Flutter. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/primaryColor</item>
    </style>
</resources>
